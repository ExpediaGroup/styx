{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>ExpediaGroup/renovate-config",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "description": "Pin Scala to 2.12.x - binary incompatible across minor versions",
      "matchDatasources": [
        "maven"
      ],
      "matchPackagePatterns": [
        "^org\\.scala-lang:"
      ],
      "allowedVersions": "/^2\\.12\\./"
    }
  ]
}
